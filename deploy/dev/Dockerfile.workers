FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

COPY src/LioConecta.Workers/LioConecta.Workers.csproj src/LioConecta.Workers/
COPY src/LioConecta.Application/LioConecta.Application.csproj src/LioConecta.Application/
COPY src/LioConecta.Domain/LioConecta.Domain.csproj src/LioConecta.Domain/
COPY src/LioConecta.Infrastructure/LioConecta.Infrastructure.csproj src/LioConecta.Infrastructure/

RUN dotnet restore src/LioConecta.Workers/LioConecta.Workers.csproj

COPY src/ src/
RUN dotnet publish src/LioConecta.Workers/LioConecta.Workers.csproj -c Release -o /app/publish --no-restore

FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS runtime
WORKDIR /app
COPY --from=build /app/publish .

ENTRYPOINT ["dotnet", "LioConecta.Workers.dll"]
